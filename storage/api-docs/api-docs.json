                ],
                "summary": "Delete a photo",
                "description": "Delete a photo and its stored files.",
                "operationId": "7927835810b71ea26fb7cf98d32526be",
                "parameters": [
                    {
                        "name": "photo",
                        "in": "path",
                        "description": "ID or UUID of the photo",
