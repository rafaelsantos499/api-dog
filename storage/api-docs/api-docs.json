            "put": {
                "tags": [
                    "UserPhoto"
                ],
                "summary": "Update a photo metadata",
                "description": "Update a photo's metadata (title, description, weight, age, is_published).",
                "operationId": "13152982dcbaf5da082c458c3bf9c2d2",
                "parameters": [
                    {
                        "name": "photo",
                        "in": "path",
                        "description": "ID or UUID of the photo",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "weight": {
                                        "type": "number",
                                        "format": "float"
                                    },
                                    "age": {
                                        "type": "integer"
                                    },
                                    "title": {
                                        "type": "string",
                                        "maxLength": 255
                                    },
                                    "description": {
                                        "type": "string",
                                        "maxLength": 2000
                                    },
                                    "is_published": {
