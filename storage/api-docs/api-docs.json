                                                },
                                                "original_url": {
                                                    "type": "string"
                                                },
                                                "feed_url": {
                                                    "type": "string"
                                                },
                                                "thumb_url": {
                                                    "type": "string"
                                                },
                                                "weight": {
                                                    "type": "number"
                                                },
                                                "age": {
                                                    "type": "integer"
                                                },
                                                "title": {
                                                    "type": "string"
                                                },
                                                "description": {
                                                    "type": "string"
                                                },
