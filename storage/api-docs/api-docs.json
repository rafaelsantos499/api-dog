        "/photos/upload": {
            "post": {
                "tags": [
                    "UserPhoto"
                ],
                "summary": "Upload user photo",
                "description": "Upload a user photo.",
                "operationId": "e6e4a562028953cec523698f4dfce475",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "photo",
                                    "title"
                                ],
                                "properties": {
                                    "photo": {
                                        "description": "Photo file (jpeg, png, jpg, gif, webp, max 5MB)",
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "weight": {
                                        "description": "Weight (optional)",
                                        "type": "number",
                                        "format": "float"
                                    },
                                    "age": {
                                        "description": "Age (optional)",
                                        "type": "integer"
                                    },
                                    "title": {
                                        "description": "Title",
                                        "type": "string",
                                        "maxLength": 255
                                    },
                                    "description": {
                                        "description": "Description (optional)",
                                        "type": "string",
                                        "maxLength": 2000
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Photo uploaded successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Photo uploaded successfully."
                                        },
                                        "photo": {
                                            "properties": {
                                                "original_path": {
                                                    "type": "string"
                                                },
                                                "feed_path": {
                                                    "type": "string"
                                                },
                                                "thumb_path": {
                                                    "type": "string"
                                                },
                                                "original_url": {
                                                    "type": "string"
                                                },
                                                "feed_url": {
                                                    "type": "string"
                                                },
                                                "thumb_url": {
                                                    "type": "string"
                                                },
                                                "weight": {
                                                    "type": "number"
                                                },
                                                "age": {
                                                    "type": "integer"
                                                },
                                                "title": {
                                                    "type": "string"
                                                },
                                                "description": {
                                                    "type": "string"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
